			.mh-posts-stacked-title {padding:5px;padding-top:0px;padding-bottom:3px}
.mh-ticker-item-cat { display: none; }
.mh-posts-stacked-item { position: absolute; bottom: 5px; left: 5px; padding-right: 5px; padding:0px 5px }
.mh-posts-stacked-overlay { position: absolute; top: 0; right: 0; bottom: 0; left: 0; background: rgba(51, 51, 51, 0.25); }
.mh-posts-stacked-item .mh-meta {padding:0px 5px}
.mh-back-to-top {position:fixed; bottom:100px}

.wp-dark-mode-switcher{z-index: 100000}

.pagelink{color:#e2e2e2;background:#1963ac}

@font-face{src:local(open-sans);
	font-display:swap;}		</style>
		

<style>
    .table-responsive table{
        border-collapse: collapse;
        border-spacing: 0;
        table-layout: auto;
        padding: 0;
        width: 100%;
        max-width: 100%;
        margin: 0 auto 20px auto;
    }

    .table-responsive {
        overflow-x: auto;
        min-height: 0.01%;
        margin-bottom: 20px;
    }

    .table-responsive::-webkit-scrollbar {
        width: 10px;
        height: 10px;
    }
    .table-responsive::-webkit-scrollbar-thumb {
        background: #dddddd;
        border-radius: 2px;
    }
